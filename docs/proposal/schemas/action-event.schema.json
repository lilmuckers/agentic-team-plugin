{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/agentic-team-plugin/docs/proposal/schemas/action-event.schema.json",
  "title": "Proposed agent framework action event",
  "description": "Proposed append-only event envelope for task mutations, wrapper actions, and runtime usage telemetry.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "eventId",
    "eventType",
    "eventSource",
    "timestamp",
    "project",
    "status"
  ],
  "properties": {
    "eventId": {
      "type": "string",
      "minLength": 1
    },
    "eventType": {
      "type": "string",
      "minLength": 1
    },
    "eventSource": {
      "type": "string",
      "enum": ["task-service", "wrapper", "runtime", "ingester", "system"]
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "project": {
      "type": "string",
      "minLength": 1
    },
    "taskId": {
      "type": ["string", "null"]
    },
    "runId": {
      "type": ["string", "null"]
    },
    "correlationId": {
      "type": ["string", "null"]
    },
    "parentEventId": {
      "type": ["string", "null"]
    },
    "agentType": {
      "type": ["string", "null"],
      "enum": [
        "orchestrator",
        "triage",
        "spec",
        "builder",
        "qa",
        "security",
        "release-manager",
        "specialist",
        "system",
        "human",
        null
      ]
    },
    "agentId": {
      "type": ["string", "null"]
    },
    "sessionKey": {
      "type": ["string", "null"]
    },
    "provider": {
      "type": ["string", "null"]
    },
    "model": {
      "type": ["string", "null"]
    },
    "status": {
      "type": "string",
      "enum": [
        "started",
        "succeeded",
        "failed",
        "blocked",
        "cancelled",
        "timed-out",
        "invalid"
      ]
    },
    "outcome": {
      "type": ["string", "null"]
    },
    "durationMs": {
      "type": ["integer", "null"],
      "minimum": 0
    },
    "costUsd": {
      "type": ["number", "null"],
      "minimum": 0
    },
    "usage": {
      "$ref": "#/$defs/usage"
    },
    "target": {
      "$ref": "#/$defs/target"
    },
    "artifacts": {
      "$ref": "#/$defs/artifacts"
    },
    "data": {
      "type": "object",
      "description": "Event-specific metadata payload.",
      "additionalProperties": true,
      "default": {}
    },
    "retryCount": {
      "type": ["integer", "null"],
      "minimum": 0
    }
  },
  "$defs": {
    "usage": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "properties": {
        "inputTokens": {
          "type": ["integer", "null"],
          "minimum": 0
        },
        "outputTokens": {
          "type": ["integer", "null"],
          "minimum": 0
        },
        "totalTokens": {
          "type": ["integer", "null"],
          "minimum": 0
        },
        "cacheReadTokens": {
          "type": ["integer", "null"],
          "minimum": 0
        },
        "cacheWriteTokens": {
          "type": ["integer", "null"],
          "minimum": 0
        }
      },
      "default": null
    },
    "target": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "required": ["kind", "id"],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "task",
            "named-agent",
            "ephemeral-agent",
            "issue",
            "pull-request",
            "wiki-page",
            "release",
            "callback",
            "human",
            "framework",
            "workspace",
            "repo",
            "tool",
            "none"
          ]
        },
        "id": {
          "type": ["string", "null"]
        },
        "url": {
          "type": ["string", "null"],
          "format": "uri-reference"
        }
      },
      "default": null
    },
    "artifacts": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "properties": {
        "issueNumber": {
          "type": ["integer", "null"],
          "minimum": 1
        },
        "prNumber": {
          "type": ["integer", "null"],
          "minimum": 1
        },
        "branch": {
          "type": ["string", "null"]
        },
        "commitSha": {
          "type": ["string", "null"],
          "pattern": "^[0-9a-f]{7,40}$"
        },
        "releaseVersion": {
          "type": ["string", "null"]
        },
        "decisionRecord": {
          "type": ["string", "null"]
        },
        "urls": {
          "type": "array",
          "items": {
            "type": "string",
            "format": "uri-reference"
          },
          "default": []
        }
      },
      "default": null
    }
  }
}
