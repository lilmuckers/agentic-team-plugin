{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "version": 2,
  "description": "Proposed event type registry for the split task-state, wrapper-action, and runtime-usage telemetry model.",
  "families": {
    "task": [
      "task.created",
      "task.updated",
      "task.transitioned",
      "task.invalidated",
      "task.note.added",
      "task.artifact.linked"
    ],
    "agent": [
      "agent.dispatch",
      "agent.run.started",
      "agent.run.completed",
      "agent.run.failed"
    ],
    "callback": [
      "callback.sent",
      "callback.validated"
    ],
    "repo": [
      "repo.sync"
    ],
    "issue": [
      "issue.created",
      "issue.commented"
    ],
    "pr": [
      "pr.created",
      "pr.body.updated",
      "pr.comment.added",
      "pr.line_comment.added"
    ],
    "label": [
      "label.applied"
    ],
    "wiki": [
      "wiki.updated"
    ],
    "release": [
      "release.tag.cut",
      "release.notes.generated"
    ],
    "framework": [
      "framework.deployed",
      "framework.agent_primed"
    ],
    "tool": [
      "tool.exec.started",
      "tool.exec.completed",
      "tool.exec.failed"
    ]
  },
  "actions": {
    "task.created": {
      "family": "task",
      "eventSource": "task-service",
      "targetKinds": ["task"],
      "recommendedData": ["kind", "title", "state", "priority", "reasonCode"]
    },
    "task.updated": {
      "family": "task",
      "eventSource": "task-service",
      "targetKinds": ["task"],
      "recommendedData": ["changedFields", "reasonCode"]
    },
    "task.transitioned": {
      "family": "task",
      "eventSource": "task-service",
      "targetKinds": ["task"],
      "recommendedData": ["fromState", "toState", "reasonCode", "summary"]
    },
    "task.invalidated": {
      "family": "task",
      "eventSource": "task-service",
      "targetKinds": ["task"],
      "recommendedData": ["reasonCode", "summary"]
    },
    "task.note.added": {
      "family": "task",
      "eventSource": "task-service",
      "targetKinds": ["task"],
      "recommendedData": ["noteType"]
    },
    "task.artifact.linked": {
      "family": "task",
      "eventSource": "task-service",
      "targetKinds": ["task", "issue", "pull-request", "wiki-page", "release"],
      "recommendedData": ["artifactKind", "artifactRef"]
    },
    "agent.dispatch": {
      "family": "agent",
      "eventSource": "wrapper",
      "targetKinds": ["named-agent", "ephemeral-agent", "human"],
      "recommendedData": ["targetAgentType", "reasonCode", "expectedCallbackAt"]
    },
    "agent.run.started": {
      "family": "agent",
      "eventSource": "runtime",
      "targetKinds": ["named-agent", "ephemeral-agent"],
      "recommendedData": ["runKind"]
    },
    "agent.run.completed": {
      "family": "agent",
      "eventSource": "runtime",
      "targetKinds": ["named-agent", "ephemeral-agent"],
      "recommendedData": ["runKind", "result"]
    },
    "agent.run.failed": {
      "family": "agent",
      "eventSource": "runtime",
      "targetKinds": ["named-agent", "ephemeral-agent"],
      "recommendedData": ["runKind", "failureType", "reasonCode"]
    },
    "callback.sent": {
      "family": "callback",
      "eventSource": "wrapper",
      "targetKinds": ["callback", "named-agent"],
      "recommendedData": ["callbackStatus", "recipient"]
    },
    "callback.validated": {
      "family": "callback",
      "eventSource": "wrapper",
      "targetKinds": ["callback"],
      "recommendedData": ["valid", "reasonCode"]
    },
    "repo.sync": {
      "family": "repo",
      "eventSource": "wrapper",
      "targetKinds": ["repo", "workspace"],
      "recommendedData": ["syncMode", "result"]
    },
    "issue.created": {
      "family": "issue",
      "eventSource": "wrapper",
      "targetKinds": ["issue"],
      "recommendedData": ["labels", "issueType"]
    },
    "issue.commented": {
      "family": "issue",
      "eventSource": "wrapper",
      "targetKinds": ["issue"],
      "recommendedData": ["commentPurpose"]
    },
    "pr.created": {
      "family": "pr",
      "eventSource": "wrapper",
      "targetKinds": ["pull-request"],
      "recommendedData": ["baseBranch", "headBranch"]
    },
    "pr.body.updated": {
      "family": "pr",
      "eventSource": "wrapper",
      "targetKinds": ["pull-request"],
      "recommendedData": ["updatePurpose"]
    },
    "pr.comment.added": {
      "family": "pr",
      "eventSource": "wrapper",
      "targetKinds": ["pull-request"],
      "recommendedData": ["commentPurpose"]
    },
    "pr.line_comment.added": {
      "family": "pr",
      "eventSource": "wrapper",
      "targetKinds": ["pull-request"],
      "recommendedData": ["filePath", "lineNumber", "commentPurpose"]
    },
    "label.applied": {
      "family": "label",
      "eventSource": "wrapper",
      "targetKinds": ["issue", "pull-request"],
      "recommendedData": ["label", "reasonCode"]
    },
    "wiki.updated": {
      "family": "wiki",
      "eventSource": "wrapper",
      "targetKinds": ["wiki-page"],
      "recommendedData": ["page", "updatePurpose"]
    },
    "release.tag.cut": {
      "family": "release",
      "eventSource": "wrapper",
      "targetKinds": ["release"],
      "recommendedData": ["releaseVersion", "releaseStage"]
    },
    "release.notes.generated": {
      "family": "release",
      "eventSource": "wrapper",
      "targetKinds": ["release"],
      "recommendedData": ["fromTag", "toTag", "releaseStage"]
    },
    "framework.deployed": {
      "family": "framework",
      "eventSource": "wrapper",
      "targetKinds": ["framework", "workspace"],
      "recommendedData": ["deployedSha", "project"]
    },
    "framework.agent_primed": {
      "family": "framework",
      "eventSource": "wrapper",
      "targetKinds": ["named-agent"],
      "recommendedData": ["project", "agentType", "result"]
    },
    "tool.exec.started": {
      "family": "tool",
      "eventSource": "runtime",
      "targetKinds": ["tool"],
      "recommendedData": ["toolName"]
    },
    "tool.exec.completed": {
      "family": "tool",
      "eventSource": "runtime",
      "targetKinds": ["tool"],
      "recommendedData": ["toolName", "result"]
    },
    "tool.exec.failed": {
      "family": "tool",
      "eventSource": "runtime",
      "targetKinds": ["tool"],
      "recommendedData": ["toolName", "failureType", "reasonCode"]
    }
  }
}
