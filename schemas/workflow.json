{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Agentic Workflow Contract",
  "type": "object",
  "required": ["name", "description", "steps", "on_blocked", "on_failure", "loops"],
  "properties": {
    "name": { "type": "string", "minLength": 1 },
    "description": { "type": "string", "minLength": 1 },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "agent", "preconditions", "postconditions", "output"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "agent": { "type": "string", "minLength": 1 },
          "preconditions": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          },
          "postconditions": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          },
          "output": { "type": "string", "minLength": 1 }
        },
        "additionalProperties": false
      }
    },
    "on_blocked": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "on_failure": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "loops": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["from", "to", "trigger"],
        "properties": {
          "from": { "type": "string", "minLength": 1 },
          "to": { "type": "string", "minLength": 1 },
          "trigger": { "type": "string", "minLength": 1 }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
