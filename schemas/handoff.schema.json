{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Agent handoff",
  "type": "object",
  "required": ["from", "to", "task", "expected_output", "callback_to", "allowed_outcomes"],
  "properties": {
    "from": { "type": "string" },
    "to": { "type": "string" },
    "task": { "type": "string" },
    "inputs": {
      "type": "array",
      "items": { "type": "string" }
    },
    "expected_output": { "type": "string" },
    "done_criteria": {
      "type": "array",
      "items": { "type": "string" }
    },
    "callback_to": { "type": "string" },
    "task_id": { "type": "string" },
    "allowed_outcomes": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["DONE", "BLOCKED", "FAILED", "NEEDS_REVIEW"]
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "notes": { "type": "string" }
  },
  "additionalProperties": false
}
